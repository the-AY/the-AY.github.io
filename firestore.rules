rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. System Stats (Global counter)
    match /system/stats {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalAnalyzed']); 
    }

    // 2. Job Hunter Extension Profiles
    match /job_hunter_profiles/{docId} {
      allow create, update: if true; 
      allow read: if request.auth != null && request.auth.token.email == "adishyermal@gmail.com";
    }

    // 3. ATS Analysis Logs
    match /analysis_logs/{docId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
      allow read: if request.auth != null && request.auth.token.email == "adishyermal@gmail.com";
    }
  }
}
